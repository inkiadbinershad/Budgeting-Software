{
  "name": "budget-tracker",
  "version": "1.0.0",
  "description": "A simple local app to manage personal or household expenses",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run react-dev\" \"wait-on http://localhost:3001 && electron .\"",
    "react-dev": "cross-env PORT=3001 BROWSER=none react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run react-dev\" \"wait-on http://localhost:3001 && electron .\""
  },
  "dependencies": {
    "electron": "^25.0.0",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.2.2",
    "pdfjs-dist": "^5.4.296",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.0.0",
    "react-pdf": "^10.2.0",
    "recharts": "^2.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "react-scripts": "^5.0.1",
    "tailwindcss": "^3.4.17",
    "wait-on": "^7.0.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
